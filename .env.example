# ─── Google OAuth (staff login) ────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Authorized redirect URIs:
#      http://localhost:8000/auth/callback
#      https://primemicromarkets.com/auth/callback
# 4. Copy client ID and secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change-me-generate-with-secrets-token-hex-32
# Comma-separated Gmail addresses allowed into the internal app
ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# ─── App ────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./smart_vend.db
GOOGLE_SHEETS_CREDS_FILE=./secrets/service_account.json
SPREADSHEET_ID=your_google_spreadsheet_id_here
DEBUG=false

# ─── AI / Lead generation ───────────────────────────────────────────────────────
# Required for /leads/ agent jobs (research + email drafting)
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
GMAIL_USER=primemicromarkets@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GOOGLE_BOOKING_URL=https://calendar.google.com/calendar/appointments/schedules/...
COMPANY_BLURB=Prime Vending is a veteran-owned smart cooler vending company serving Bay County, FL.

# ─── Chatbot AI providers (all optional) ────────────────────────────────────────
# The active chatbot provider is selected in Admin → Customer Service → AI Settings.
# You only need keys for the provider(s) you want to use.

# Anthropic Claude (paid, default chatbot provider)
# ANTHROPIC_API_KEY already set above — no duplicate needed

# Groq (free tier, very fast Llama inference — good cloud alternative to Ollama)
GROQ_API_KEY=gsk_...

# OpenAI (paid)
OPENAI_API_KEY=sk-...

# Google Gemini (free tier)
GEMINI_API_KEY=AIza...

# ─── Ollama local AI ────────────────────────────────────────────────────────────
# Ollama is a system-level install (https://ollama.com) — NOT a pip package.
# Runs on the same machine as the app; no API key required.
# For local dev: leave as-is. For cloud: point to your Ollama VM's IP.
# Pull models first: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434/v1
